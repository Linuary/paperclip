# 演示环境配置

PORT=3100
SERVE_UI=true
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
PAPERCLIP_PUBLIC_URL=https://demo.example.com
PAPERCLIP_STORAGE_PROVIDER=s3
PAPERCLIP_STORAGE_S3_BUCKET=paperclip-demo
PAPERCLIP_STORAGE_S3_REGION=us-east-1

# 数据库配置（请替换为实际值）
DATABASE_URL=postgres://paperclip:password@demo-db:5432/paperclip
BETTER_AUTH_SECRET=your-demo-secret
