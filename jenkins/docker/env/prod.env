# 生产环境配置

PORT=3100
SERVE_UI=true
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
PAPERCLIP_PUBLIC_URL=https://app.example.com
PAPERCLIP_STORAGE_PROVIDER=s3
PAPERCLIP_STORAGE_S3_BUCKET=paperclip-prod
PAPERCLIP_STORAGE_S3_REGION=us-east-1
PAPERCLIP_DB_BACKUP_ENABLED=true
PAPERCLIP_DB_BACKUP_INTERVAL_MINUTES=60
PAPERCLIP_DB_BACKUP_RETENTION_DAYS=30

# 数据库配置（请替换为实际值）
DATABASE_URL=postgres://paperclip:password@prod-db:5432/paperclip
BETTER_AUTH_SECRET=your-prod-secret
