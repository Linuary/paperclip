<?xml version='1.1' encoding='UTF-8'?>
<flow-definition plugin="workflow-job">
  <description>Paperclip 通用构建部署 Pipeline</description>
  <keepDependencies>false</keepDependencies>
  <properties>
    <hudson.model.ParametersDefinitionProperty>
      <parameterDefinitions>
        <hudson.model.StringParameterDefinition>
          <name>GIT_URL</name>
          <defaultValue>https://github.com/Linuary/paperclip.git</defaultValue>
          <description>Git 仓库地址</description>
          <trim>false</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.ChoiceParameterDefinition>
          <name>BRANCH</name>
          <choices>
            <string>dev-custom</string>
            <string>main</string>
            <string>master</string>
            <string>release/*</string>
          </choices>
          <description>分支</description>
        </hudson.model.ChoiceParameterDefinition>
        <hudson.model.ChoiceParameterDefinition>
          <name>PROJECT_TYPE</name>
          <choices>
            <string>node-docker</string>
            <string>java-maven</string>
            <string>java-gradle</string>
            <string>python</string>
            <string>go</string>
            <string>custom</string>
          </choices>
          <description>项目类型</description>
        </hudson.model.ChoiceParameterDefinition>
        <hudson.model.ChoiceParameterDefinition>
          <name>DEPLOY_MODE</name>
          <choices>
            <string>combined</string>
            <string>split</string>
          </choices>
          <description>部署模式：combined=前后端一个容器，split=前后端分别容器</description>
        </hudson.model.ChoiceParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>IMAGE_NAME</name>
          <defaultValue></defaultValue>
          <description>镜像名称（留空自动从项目名生成）</description>
          <trim>false</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>BUILD_ARGS</name>
          <defaultValue></defaultValue>
          <description>Docker build-arg，格式：KEY1=VAL1,KEY2=VAL2</description>
          <trim>false</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.BooleanParameterDefinition>
          <name>USE_VERSION_TAG</name>
          <defaultValue>false</defaultValue>
          <description>使用版本标签（build号），否则使用固定标签自动覆盖</description>
        </hudson.model.BooleanParameterDefinition>
        <hudson.model.BooleanParameterDefinition>
          <name>DEPLOY_CLAUDE_CODE</name>
          <defaultValue>false</defaultValue>
          <description>部署 Claude Code 容器</description>
        </hudson.model.BooleanParameterDefinition>
        <hudson.model.BooleanParameterDefinition>
          <name>DEPLOY_OPENAI_CODEX</name>
          <defaultValue>false</defaultValue>
          <description>部署 OpenAI Codex 容器</description>
        </hudson.model.BooleanParameterDefinition>
        <hudson.model.BooleanParameterDefinition>
          <name>DEPLOY_OPENCODE</name>
          <defaultValue>false</defaultValue>
          <description>部署 OpenCode 容器</description>
        </hudson.model.BooleanParameterDefinition>
        <hudson.model.BooleanParameterDefinition>
          <name>DEPLOY_GEMINI_CLI</name>
          <defaultValue>false</defaultValue>
          <description>部署 Google Gemini 容器</description>
        </hudson.model.BooleanParameterDefinition>
        <hudson.model.ChoiceParameterDefinition>
          <name>ACTION</name>
          <choices>
            <string>build+deploy</string>
            <string>build</string>
            <string>deploy</string>
            <string>restart</string>
          </choices>
          <description>执行动作</description>
        </hudson.model.ChoiceParameterDefinition>
        <hudson.model.ChoiceParameterDefinition>
          <name>TARGET_ENV</name>
          <choices>
            <string>local</string>
            <string>dev</string>
            <string>test</string>
            <string>demo</string>
            <string>staging</string>
            <string>prod</string>
          </choices>
          <description>目标环境</description>
        </hudson.model.ChoiceParameterDefinition>
        <hudson.model.ChoiceParameterDefinition>
          <name>DEPLOY_METHOD</name>
          <choices>
            <string>docker-compose</string>
            <string>kubernetes</string>
          </choices>
          <description>部署方式</description>
        </hudson.model.ChoiceParameterDefinition>
        <hudson.model.BooleanParameterDefinition>
          <name>USE_EXTERNAL_DB</name>
          <defaultValue>true</defaultValue>
          <description>使用外部数据库（true=连接外部DB，false=创建内部PG容器）</description>
        </hudson.model.BooleanParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>TARGET_HOST</name>
          <defaultValue>172.19.25.144</defaultValue>
          <description>部署目标服务器（使用内网 IP）</description>
          <trim>false</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>TARGET_USER</name>
          <defaultValue>root</defaultValue>
          <description>SSH 用户</description>
          <trim>false</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.StringParameterDefinition>
          <name>TARGET_PORT</name>
          <defaultValue>22</defaultValue>
          <description>SSH 端口</description>
          <trim>false</trim>
        </hudson.model.StringParameterDefinition>
        <hudson.model.TextParameterDefinition>
          <name>ENV_VARS</name>
          <defaultValue>PORT=8088
SERVE_UI=true
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
BETTER_AUTH_SECRET=paperclip-dev-secret
PAPERCLIP_ALLOWED_HOSTNAMES=47.236.51.128</defaultValue>
          <description>额外环境变量，每行一个 KEY=VALUE</description>
        </hudson.model.TextParameterDefinition>
        <hudson.model.PasswordParameterDefinition>
          <name>SECRET_VARS</name>
          <defaultValue></defaultValue>
          <description>敏感环境变量（Jenkins 自动遮蔽，每次构建时手动输入或从 Credentials 获取）</description>
        </hudson.model.PasswordParameterDefinition>
      </parameterDefinitions>
    </hudson.model.ParametersDefinitionProperty>
  </properties>
  <definition class="org.jenkinsci.plugins.workflow.cps.CpsScmFlowDefinition" plugin="workflow-cps">
    <scriptPath>jenkins/Jenkinsfile</scriptPath>
    <scm class="hudson.plugins.git.GitSCM" plugin="git">
      <configVersion>2</configVersion>
      <userRemoteConfigs>
        <hudson.plugins.git.UserRemoteConfig>
          <url>https://github.com/Linuary/paperclip.git</url>
          <credentialsId>github-credentials</credentialsId>
        </hudson.plugins.git.UserRemoteConfig>
      </userRemoteConfigs>
      <branches>
        <hudson.plugins.git.BranchSpec>
          <name>*/dev-custom</name>
        </hudson.plugins.git.BranchSpec>
      </branches>
    </scm>
    <sandbox>true</sandbox>
  </definition>
  <triggers/>
  <disabled>false</disabled>
</flow-definition>
