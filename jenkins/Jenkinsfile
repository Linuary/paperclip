/**
 * Jenkins 通用构建部署 Pipeline
 *
 * 支持任意项目的 Docker 化构建和部署。
 * 使用方式：在 Jenkins Job 中配置此 Jenkinsfile，构建时填入目标项目参数。
 */

pipeline {
    agent any

    parameters {
        // ---- 代码来源 ----
        string(name: 'GIT_URL', description: 'Git 仓库地址')
        choice(name: 'BRANCH', choices: ['main', 'master', 'dev-custom', 'release/*'], description: '分支')

        // ---- 项目类型 ----
        choice(name: 'PROJECT_TYPE', choices: [
            'node-docker',
            'java-maven',
            'java-gradle',
            'python',
            'go',
            'custom'
        ], description: '项目类型')

        // ---- 构建配置 ----
        string(name: 'BUILD_COMMAND', defaultValue: '', description: '自定义构建命令（PROJECT_TYPE=custom 时使用）')
        string(name: 'DOCKERFILE', defaultValue: 'jenkins/Dockerfile.backend', description: 'Dockerfile 路径')
        string(name: 'IMAGE_NAME', defaultValue: '', description: '镜像名称（留空自动从项目名生成）')
        string(name: 'BUILD_ARGS', defaultValue: '', description: 'Docker build-arg，格式：KEY1=VAL1,KEY2=VAL2')

        // ---- AI CLI 工具配置（独立容器，按需选择） ----
        booleanParam(name: 'DEPLOY_CLAUDE_CODE', defaultValue: false, description: '部署 Claude Code 容器')
        booleanParam(name: 'DEPLOY_OPENAI_CODEX', defaultValue: false, description: '部署 OpenAI Codex 容器')
        booleanParam(name: 'DEPLOY_OPENCODE', defaultValue: false, description: '部署 OpenCode 容器')
        booleanParam(name: 'DEPLOY_GEMINI_CLI', defaultValue: false, description: '部署 Google Gemini 容器')

        // ---- 部署配置 ----
        choice(name: 'ACTION', choices: ['build+deploy', 'build', 'deploy', 'restart'], description: '执行动作')
        choice(name: 'TARGET_ENV', choices: ['local', 'dev', 'test', 'demo', 'staging', 'prod'], description: '目标环境')
        choice(name: 'DEPLOY_METHOD', choices: ['docker-compose', 'kubernetes'], description: '部署方式')
        string(name: 'TARGET_HOST', defaultValue: '172.19.25.144', description: '部署目标服务器')
        string(name: 'TARGET_USER', defaultValue: 'root', description: 'SSH 用户')
        string(name: 'TARGET_PORT', defaultValue: '22', description: 'SSH 端口')
        string(name: 'K8S_NAMESPACE', defaultValue: 'default', description: 'K8s 命名空间')

        // ---- 镜像仓库 ----
        booleanParam(name: 'PUSH_REGISTRY', defaultValue: false, description: '是否推送到镜像仓库')
        string(name: 'REGISTRY', defaultValue: 'harbor.example.com', description: '镜像仓库地址')
        booleanParam(name: 'USE_VERSION_TAG', defaultValue: false, description: '使用版本标签（build号），否则使用固定标签自动覆盖')

        // ---- 环境变量注入 ----
        text(name: 'ENV_VARS', defaultValue: '', description: '额外环境变量，每行一个 KEY=VALUE')
        password(name: 'SECRET_VARS', defaultValue: '', description: '敏感环境变量（Jenkins 自动遮蔽）')
    }

    environment {
        TAG = "${params.BRANCH}-${params.TARGET_ENV}"
    }

    stages {
        // ============================================
        // Stage 0: 拉取代码
        // ============================================
        stage('Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: params.BRANCH]],
                    userRemoteConfigs: [[url: params.GIT_URL]]
                ])
            }
        }

        // ============================================
        // Stage 1: 检测与验证
        // ============================================
        stage('Detect & Validate') {
            steps {
                script {
                    // 自动检测项目类型
                    env.DETECTED_TYPE = params.PROJECT_TYPE

                    // 计算 TAG（根据 USE_VERSION_TAG 参数）
                    if (params.USE_VERSION_TAG) {
                        env.TAG = "${params.BRANCH}-${params.TARGET_ENV}-${env.BUILD_NUMBER}"
                    }

                    // 计算部署模式标志
                    env.IS_LOCAL = (params.TARGET_HOST == 'localhost' || params.TARGET_HOST == '127.0.0.1') ? 'true' : 'false'
                    env.IS_K8S = (params.DEPLOY_METHOD == 'kubernetes') ? 'true' : 'false'

                    // 自动生成镜像名
                    if (params.IMAGE_NAME) {
                        env.FINAL_IMAGE_NAME = params.IMAGE_NAME
                    } else {
                        def repoName = params.GIT_URL.split('/').last().replace('.git', '')
                        if (params.PUSH_REGISTRY) {
                            env.FINAL_IMAGE_NAME = "${params.REGISTRY}/${repoName}"
                        } else {
                            env.FINAL_IMAGE_NAME = repoName
                        }
                    }

                    echo "========================================"
                    echo "Project Type: ${env.DETECTED_TYPE}"
                    echo "Image Name:   ${env.FINAL_IMAGE_NAME}:${TAG}"
                    echo "Target Env:   ${params.TARGET_ENV}"
                    echo "Deploy Method: ${params.DEPLOY_METHOD}"
                    echo "Target Host:  ${params.TARGET_HOST}"
                    echo "Is Local:     ${env.IS_LOCAL}"
                    echo "Is K8s:       ${env.IS_K8S}"
                    echo "========================================"
                }
            }
        }

        // ============================================
        // Stage 2: 构建
        // ============================================
        stage('Build') {
            when { expression { params.ACTION in ['build', 'build+deploy'] } }
            steps {
                script {
                    // 清理旧镜像（使用固定标签会自动覆盖，但清理悬空镜像释放空间）
                    sh "docker image prune -f || true"

                    // 解析 build-args
                    def buildArgs = ''
                    if (params.BUILD_ARGS) {
                        buildArgs = params.BUILD_ARGS.split(',').collect {
                            "--build-arg ${it.trim()}"
                        }.join(' ')
                    }

                    // 根据项目类型执行构建
                    switch (env.DETECTED_TYPE) {
                        case 'node-docker':
                            sh "docker build -f ${params.DOCKERFILE} ${buildArgs} -t ${FINAL_IMAGE_NAME}:${TAG} ."
                            break
                        case 'java-maven':
                            sh 'mvn clean package -DskipTests'
                            sh "docker build -f ${params.DOCKERFILE} ${buildArgs} -t ${FINAL_IMAGE_NAME}:${TAG} ."
                            break
                        case 'java-gradle':
                            sh './gradlew bootJar'
                            sh "docker build -f ${params.DOCKERFILE} ${buildArgs} -t ${FINAL_IMAGE_NAME}:${TAG} ."
                            break
                        case 'python':
                            sh "docker build -f ${params.DOCKERFILE} ${buildArgs} -t ${FINAL_IMAGE_NAME}:${TAG} ."
                            break
                        case 'go':
                            sh "docker build -f ${params.DOCKERFILE} ${buildArgs} -t ${FINAL_IMAGE_NAME}:${TAG} ."
                            break
                        case 'custom':
                            if (params.BUILD_COMMAND) {
                                sh params.BUILD_COMMAND
                            }
                            if (fileExists(params.DOCKERFILE)) {
                                sh "docker build -f ${params.DOCKERFILE} ${buildArgs} -t ${FINAL_IMAGE_NAME}:${TAG} ."
                            }
                            break
                    }

                    // 写入环境变量文件
                    def envContent = params.ENV_VARS ?: ''
                    if (params.SECRET_VARS) {
                        envContent += '\n' + params.SECRET_VARS
                    }
                    writeFile file: '.env', text: envContent.trim()

                    // 推送到镜像仓库
                    if (params.PUSH_REGISTRY && env.IS_LOCAL != 'true') {
                        sh "docker tag ${FINAL_IMAGE_NAME}:${TAG} ${FINAL_IMAGE_NAME}:latest"
                        withCredentials([usernamePassword(
                            credentialsId: 'docker-registry-auth',
                            usernameVariable: 'REGISTRY_USER',
                            passwordVariable: 'REGISTRY_PASS'
                        )]) {
                            sh "echo \$REGISTRY_PASS | docker login ${params.REGISTRY} -u \$REGISTRY_USER --password-stdin"
                            sh "docker push ${FINAL_IMAGE_NAME}:${TAG}"
                            sh "docker push ${FINAL_IMAGE_NAME}:latest"
                        }
                    }

                    // 远程部署且不推送仓库：导出 tar 包
                    if (env.IS_LOCAL != 'true' && !params.PUSH_REGISTRY && env.IS_K8S != 'true') {
                        sh "docker save ${FINAL_IMAGE_NAME}:${TAG} | gzip > image.tar.gz"
                    }
                }
            }
        }

        // ============================================
        // Stage 3: 部署
        // ============================================
        stage('Deploy') {
            when { expression { params.ACTION in ['deploy', 'build+deploy'] } }
            steps {
                script {
                    // 构建 AI CLI profiles
                    def aiProfiles = []
                    if (params.DEPLOY_CLAUDE_CODE) aiProfiles.add('claude-code')
                    if (params.DEPLOY_OPENAI_CODEX) aiProfiles.add('codex')
                    if (params.DEPLOY_OPENCODE) aiProfiles.add('opencode')
                    if (params.DEPLOY_GEMINI_CLI) aiProfiles.add('gemini')
                    def profilesArg = aiProfiles.collect { "--profile ${it}" }.join(' ')

                    if (env.IS_K8S == 'true') {
                        // Kubernetes 部署
                        sh """
                            kubectl set image deployment/${env.FINAL_IMAGE_NAME} \
                                ${env.FINAL_IMAGE_NAME}=${env.FINAL_IMAGE_NAME}:${TAG} \
                                -n ${params.K8S_NAMESPACE}
                            kubectl rollout status deployment/${env.FINAL_IMAGE_NAME} \
                                -n ${params.K8S_NAMESPACE} --timeout=300s
                        """
                    } else if (env.IS_LOCAL == 'true') {
                        // 本地部署（Jenkins agent 与目标服务器同机）
                        sh 'mkdir -p /opt/app && cp jenkins/docker/docker-compose.deploy.yml .env /opt/app/'
                        sh "docker compose -f /opt/app/docker-compose.deploy.yml --profile combined ${profilesArg} --env-file /opt/app/.env up -d"
                    } else {
                        // 远程 SSH 部署
                        withCredentials([sshUserPrivateKey(
                            credentialsId: 'deploy-ssh-key',
                            keyFileVariable: 'SSH_KEY',
                            usernameVariable: 'SSH_USER'
                        )]) {
                            // 确定需要传输的文件
                            def filesToCopy = 'jenkins/docker/docker-compose.deploy.yml .env'
                            if (!params.PUSH_REGISTRY) {
                                filesToCopy += ' image.tar.gz'
                            }

                            // 传输文件到远程服务器 /tmp/ 目录
                            sh """
                                scp -i \$SSH_KEY -o StrictHostKeyChecking=no \
                                    ${filesToCopy} \
                                    \$SSH_USER@${params.TARGET_HOST}:/tmp/
                            """

                            // 传输部署脚本
                            sh """
                                scp -i \$SSH_KEY -o StrictHostKeyChecking=no \
                                    jenkins/scripts/remote-deploy.sh \
                                    \$SSH_USER@${params.TARGET_HOST}:/tmp/
                            """

                            // 设置环境变量并执行远程部署脚本
                            sh """
                                ssh -i \$SSH_KEY -o StrictHostKeyChecking=no \
                                    \$SSH_USER@${params.TARGET_HOST} \
                                    "export AI_PROFILES='${profilesArg}' && bash /tmp/remote-deploy.sh"
                            """
                        }
                    }
                }
            }
        }

        // ============================================
        // Stage 4: 重启
        // ============================================
        stage('Restart') {
            when { expression { params.ACTION == 'restart' } }
            steps {
                script {
                    if (env.IS_K8S == 'true') {
                        // Kubernetes 重启
                        sh "kubectl rollout restart deployment/${env.FINAL_IMAGE_NAME} -n ${params.K8S_NAMESPACE}"
                    } else if (env.IS_LOCAL == 'true') {
                        // 本地重启
                        sh 'docker compose -f /opt/app/docker-compose.deploy.yml restart'
                    } else {
                        // 远程 SSH 重启
                        withCredentials([sshUserPrivateKey(
                            credentialsId: 'deploy-ssh-key',
                            keyFileVariable: 'SSH_KEY',
                            usernameVariable: 'SSH_USER'
                        )]) {
                            sh """
                                ssh -i \$SSH_KEY -p ${params.TARGET_PORT} -o StrictHostKeyChecking=no \
                                    \$SSH_USER@${params.TARGET_HOST} \
                                    "cd /opt/app && docker compose -f docker-compose.deploy.yml restart"
                            """
                        }
                    }
                }
            }
        }

        // ============================================
        // Stage 5: 健康检查
        // ============================================
        stage('Health Check') {
            when { expression { params.ACTION != 'build' } }
            steps {
                script {
                    // 确定检查目标
                    def baseUrl
                    if (env.IS_K8S == 'true') {
                        baseUrl = "http://${env.FINAL_IMAGE_NAME}.${params.K8S_NAMESPACE}.svc.cluster.local"
                    } else if (env.IS_LOCAL == 'true') {
                        baseUrl = "http://localhost"
                    } else {
                        baseUrl = "http://${params.TARGET_HOST}"
                    }

                    // 从 ENV_VARS 中提取 PORT
                    def port = '3100'
                    if (params.ENV_VARS?.contains('PORT=')) {
                        def portLine = params.ENV_VARS.readLines().find { it.startsWith('PORT=') }
                        if (portLine) {
                            port = portLine.split('=')[1].trim()
                        }
                    }

                    sh """
                        echo "Checking health at ${baseUrl}:${port}/api/health"
                        for i in \$(seq 1 30); do
                            if curl -sf ${baseUrl}:${port}/api/health; then
                                echo "Health check passed!"
                                exit 0
                            fi
                            echo "Attempt \$i/30 failed, retrying in 2s..."
                            sleep 2
                        done
                        echo "Health check timeout after 60s (non-fatal)"
                    """
                }
            }
        }
    }

    post {
        always {
            // 清理构建产物
            cleanWs()
        }
        success {
            echo "Pipeline completed successfully!"
        }
        failure {
            echo "Pipeline failed!"
        }
    }
}
